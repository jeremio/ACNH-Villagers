{
  "name": "list-villagers",
  "type": "module",
  "version": "2.1.0",
  "packageManager": "pnpm@10.28.2",
  "description": "Display villagers from Animal Crossing New Horizons with optimized filtering",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "knip": "knip",
    "analyze": "vite build --mode analyze",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "performance": "vite build --mode analyze && npm run preview",
    "prepare": "husky",
    "lint-staged": "lint-staged"
  },
  "dependencies": {
    "pinia": "^3.0.4",
    "vue": "^3.5.38",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@intlify/eslint-plugin-vue-i18n": "^4.5.1",
    "@intlify/unplugin-vue-i18n": "^11.2.4",
    "@lucide/vue": "^1.21.0",
    "@playwright/test": "^1.61.1",
    "@testing-library/vue": "^8.1.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^26.0.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/language-server": "^3.3.5",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.5.0",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "knip": "^6.18.0",
    "lint-staged": "^17.0.8",
    "naive-ui": "^2.44.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^5.9.3",
    "vfonts": "^0.0.3",
    "vite": "^8.1.0",
    "vite-plugin-vue-devtools": "^8.1.3",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not ie <= 8"
  ],
  "lint-staged": {
    "*.{js,ts,vue}": [
      "eslint --fix"
    ]
  }
}
